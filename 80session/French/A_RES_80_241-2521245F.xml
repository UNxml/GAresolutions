      <p>
        <inline name="agenda item name">Financement du Bureau d’appui des Nations Unies en Haïti</inline>
      </p>
      <p>
        <docTitle>Résolution adoptée par l’Assemblée générale le 30 décembre 2025</docTitle>
      </p>
      <p xml:space="preserve">
        <docProponent refersTo="#fifthCommittee">[sur la base du rapport de la Cinquième Commission (<inline name="originating document">A/80/568, par. 19</inline>)]</docProponent>
