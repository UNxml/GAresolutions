    <preface>
      <p>
        <docNumber>80/241.</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">Financement du Bureau d’appui des Nations Unies en Haïti</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="italic">L’Assemblée générale</span>,</p>
      </formula>
      <container name="Ayant examiné" eId="container_2">
        <p xml:space="preserve">	<span class="italic">Ayant examiné</span> la note du Secrétaire général sur les modalités de financement du Bureau d’appui des Nations Unies en Haïti<authorialNote marker="1" placement="bottom" eId="authorialNote_1"><p xml:space="preserve">		<a href="https://docs.un.org/fr/A/80/499">A/80/499</a>.</p></authorialNote> et le rapport correspondant du Comité consultatif pour les questions administratives et budgétaires<authorialNote marker="2" placement="bottom" eId="authorialNote_2"><p xml:space="preserve">		<a href="https://docs.un.org/fr/A/80/567">A/80/567</a>.</p></authorialNote>,</p>
      </container>
      <container name="Rappelant" eId="container_3">
        <p xml:space="preserve">	<span class="italic">Rappelant</span> la résolution <a href="https://docs.un.org/fr/S/RES/2793(2025)">2793 (2025)</a> du Conseil de sécurité en date du 30 septembre 2025, dans laquelle le Conseil a prié le Secrétaire général de créer le Bureau d’appui des Nations Unies en Haïti avec pour mission d’apporter un soutien, principalement à la Force de répression des gangs, au Bureau intégré des Nations Unies en Haïti, à la Police nationale d’Haïti et aux Forces armées d’Haïti dans le cadre de toutes opérations conjointes avec la Force de répression des gangs, ainsi qu’un appui technique à l’Organisation des États américains, conformément aux modalités de financement qui y sont énoncées, en vue d’assumer la pleine responsabilité de l’appui logistique apporté à la Force de répression des gangs dans les six mois suivant l’adoption,</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_4" class="MercuryDocument">
        <num>1.</num>
        <content eId="para_4__content">
          <p xml:space="preserve">	<span class="italic">Souscrit</span> aux conclusions et recommandations que le Comité consultatif pour les questions administratives et budgétaires a formulées dans son rapport et prie le Secrétaire général de veiller à ce qu’il y soit pleinement donné suite ;</p>
        </content>
      </paragraph>
      <paragraph eId="para_5" class="MercuryDocument">
        <content eId="para_5__content">
          <p xml:space="preserve">
            <span class="bold">Prévisions budgétaires pour la période du 1</span>
            <sup>er</sup>
            <span class="bold"> octobre 2025 au 30 juin 2026</span>
          </p>
        </content>
      </paragraph>
      <paragraph eId="para_6" class="MercuryDocument">
        <num>2.</num>
        <content eId="para_6__content">
          <p xml:space="preserve">	<span class="italic">Autorise</span> le Secrétaire général à ouvrir un compte spécial dans lequel seront inscrites les recettes et les dépenses du Bureau d’appui des Nations Unies en Haïti ;</p>
        </content>
      </paragraph>
      <paragraph eId="para_7" class="MercuryDocument">
        <num>3.</num>
        <content eId="para_7__content">
          <p xml:space="preserve">	<span class="italic">Autorise également</span> le Secrétaire général à engager pour le Bureau des dépenses d’un montant maximum de 271 328 700 dollars des États-Unis pour la période du 1<sup>er</sup> octobre 2025 au 30 juin 2026, englobant les montants approuvés antérieurement par le Comité consultatif conformément à la section VI de la résolution <a href="https://docs.un.org/fr/A/RES/64/269">64/269</a> en date du 24 juin 2010, à savoir, pour la période du 1<sup>er</sup> octobre au 31 décembre 2025, 54 163 500 dollars et un montant de 50 000 000 dollars correspondant aux stocks stratégiques pour déploiement rapide de l’Organisation pouvant être utilisés ;</p>
        </content>
      </paragraph>
      <paragraph eId="para_8" class="MercuryDocument">
        <content eId="para_8__content">
          <p xml:space="preserve">
            <span class="bold">Modalités de financement des engagements autorisés</span>
          </p>
        </content>
      </paragraph>
      <paragraph eId="para_9" class="MercuryDocument">
        <num>4.</num>
        <content eId="para_9__content">
          <p xml:space="preserve">	<span class="italic">Décide </span>de répartir entre les États Membres, au titre de la période du 1<sup>er</sup> octobre 2025 au 30 juin 2026, un montant de 271 328 700 dollars, conformément aux catégories qu’elle a actualisées dans sa résolution <a href="https://docs.un.org/fr/A/RES/79/250">79/250</a> du 24 décembre 2024 et selon le barème des quotes-parts pour 2025 et 2026, indiqué dans sa résolution <a href="https://docs.un.org/fr/A/RES/79/249">79/249</a>, également du 24 décembre 2024 ;</p>
        </content>
      </paragraph>
      <paragraph eId="para_10" class="MercuryDocument">
        <num>5.</num>
        <content eId="para_10__content">
          <p xml:space="preserve">	<span class="italic">Décide</span> que, conformément aux dispositions de sa résolution <a href="https://docs.un.org/fr/A/RES/973(X)">973 (X)</a> du 15 décembre 1955, il sera déduit des sommes réparties en application du paragraphe 4 ci‑dessus la part de chaque État Membre dans le montant de 1 792 900 dollars qui sera inscrit au Fonds de péréquation des impôts et qui représente le montant estimatif des contributions du personnel approuvé pour le Bureau pour la période du 1<sup>er</sup> octobre 2025 au 30 juin 2026 ;</p>
        </content>
      </paragraph>
      <paragraph eId="para_12" class="MercuryDocument">
        <num>6.</num>
        <content eId="para_12__content">
          <p xml:space="preserve">	<span class="italic">Demande</span> que des contributions volontaires soient versées au fonds d’affectation spéciale des Nations Unies à l’appui de la Force de répression des gangs.</p>
        </content>
      </paragraph>
    </mainBody>
