    <preface>
      <p>
        <docNumber>80/261</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">	تسوية المنازعات الحدودية بالوسائل السلمية</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="bold italic">إن الجمعية العامة</span>،</p>
      </formula>
      <container name="إذ تشير" eId="container_2">
        <p xml:space="preserve">	<span class="bold italic">إذ تشير</span> إلى مقاصد ومبادئ ميثاق الأمم المتحدة، ولا سيما التزام الدول بتسويـة منازعاتها الدولية بالوسائل السلمية على نحو لا يعرّض السلام والأمن الدوليين أو العدل للخطر،</p>
      </container>
      <container name="وإذ تؤكد من جديد" eId="container_3">
        <p xml:space="preserve">	<span class="bold italic">وإذ تؤكد من جديد</span> مبادئ المساواة في السيادة بين الدول، والسلامة الإقليمية، والاستقلال السياسي، وحظر التهديد باستعمال القوة أو استعمالها، ومبدأ خلو ميثاق الأمم المتحدة مما يسوغ للأمم المتحدة التدخل في الشؤون التي تكون من صميم السلطان الداخلي لدولة ما، وفقاً لميثاق الأمم المتحدة وإعلان مبادئ القانون الدولي المتعلقة بالعلاقات الودية والتعاون بين الدول وفقاً لميثاق الأمم المتحدة<sup>(</sup><authorialNote marker="1" placement="bottom" eId="authorialNote_1"><p xml:space="preserve">	()	القرار <a href="https://docs.un.org/ar/A/RES/2625(XXV)">2625 (د-25)</a>، المرفق.</p></authorialNote><sup>)</sup>،</p>
      </container>
      <container name="وإذ تشير" eId="container_4">
        <p xml:space="preserve">	<span class="bold italic">وإذ تشير</span> إلى إعلان مانيلا بشأن تسوية المنازعات الدولية بالوسائل السلمية<sup>(</sup><authorialNote marker="2" placement="bottom" eId="authorialNote_2"><p xml:space="preserve">	()	القرار 37/10، المرفق.</p></authorialNote><sup>)</sup>، الذي يؤكد حرية اختيار وسائل التسوية السلمية للمنازعات وفقا لميثاق الأمم المتحدة والقانون الدولي،</p>
      </container>
      <container name="وإذ تشير أيضًا" eId="container_5">
        <p xml:space="preserve">	<span class="bold italic">وإذ تشير أيضًا</span> إلى قراراتها ذات الصلة بالتسوية السلمية للمنازعات الدولية، بما في ذلك القرار <a href="https://docs.un.org/ar/A/RES/3283(XXIX)">3283 (د-29)</a> المؤرخ 12 كانون الأول/ديسمبر 1974،</p>
      </container>
      <container name="وإذ تلاحظ" eId="container_6">
        <p xml:space="preserve">	<span class="bold italic">وإذ تلاحظ</span> أن التسوية السلمية للمنازعات الحدودية تسهم في صون السلام والأمن الدوليين وفي تعزيز العلاقات الودية وحسن الجوار بين الدول،</p>
      </container>
      <container name="وإذ ترحب" eId="container_7">
        <p xml:space="preserve">	<span class="bold italic">وإذ ترحب</span> بالجهود التي تبذلها الدول الأعضاء في حل المنازعات الحدودية بالوسائل السلمية وبالاتفاق بينها، بما فيها بلدان وسط آسيا، ولا سيما أوزبكستان وطاجيكستان وقيرغيزستان،</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_8" class="SingleTxt">
        <num>1 -</num>
        <content eId="para_8__content">
          <p xml:space="preserve">	<span class="bold italic">ترحب </span>بالجهود التي تبذلها الدول الأعضاء لحل المنازعات الحدودية بالوسائل السلمية، وتشدد على أهمية الحوار والتعاون الدولي بين الدول الأعضاء في التوصل إلى حلول دائمة ومقبولة للجميع تتوافق مع مقاصد ومبادئ ميثاق الأمم المتحدة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_9" class="SingleTxt">
        <num>2 -</num>
        <content eId="para_9__content">
          <p xml:space="preserve">	<span class="bold italic">تشير</span> إلى أن التسوية السلمية للمنازعات الحدودية يجب أن تتم وفقاً لميثاق الأمم المتحدة والالتزامات المنصوص عليها في القانون الدولي، على أساس المساواة في السيادة بين الدول، وموافقة الدول الأطراف في النزاع، وإيلاء الاعتبار الواجب لحقوقها ومصالحها المشروعة، وتحث جميع الأطراف على الامتناع عن أي إجراء من شأنه أن يؤدي إلى تفاقم هذه المنازعات أو توسيع نطاقها؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_11" class="SingleTxt">
        <num>3 -</num>
        <content eId="para_11__content">
          <p xml:space="preserve">	<span class="bold italic">تشجع</span> الدول الأعضاء، حيثما كان ذلك مناسبًا، على اللجوء إلى الوسائل السلمية لتسوية المنازعات، على النحو المنصوص عليه في ميثاق الأمم المتحدة والقانون الدولي، بطرق منها الحوار والتفاوض والوسائل السلمية الأخرى المتفق عليها بين الأطراف.</p>
        </content>
      </paragraph>
    </mainBody>
