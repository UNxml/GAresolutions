    <coverPage eId="coverPage_1">
      <p>
        <span refersTo="#publisher" class="upperLeft">
          <docAuthority refersTo="#publisher">الأمــم المتحـدة</docAuthority>
        </span>
      </p>
      <p class="upperRight">
        <docNumber refersTo="#symbol">A/RES/80/106</docNumber>
      </p>
      <p class="upperLeft">
        <img src="logo-un.jpg"></img>
        <docAuthority refersTo="#issuingBody" class="rightBig">الجمعية العامة</docAuthority>
      </p>
      <p>
        <docStatus refersTo="#generalDistribution" class="rightSmall">Distr.: General</docStatus>
      </p>
      <p>
        <docDate date="2025-12-08" class="rightSmall" refersTo="#dateOfIssuance">8 December 2025</docDate>
      </p>
      <p>
        <session refersTo="#generalAssembly" value="80" eId="coverPage_1__session_1">الدورة الثمانون</session>
      </p>
      <p>
        <inline title="59" name="agenda item">البند 59 من جدول الأعمال</inline>
      </p>
      <p>
        <inline name="agenda item name">القضاء على الاستعمار بجميع أشكاله ومظاهره</inline>
      </p>
      <p>
        <docTitle>قرار اتخذته الجمعية العامة في 5 كانون الأول/ديسمبر 2025</docTitle>
      </p>
      <p xml:space="preserve">
        <docProponent refersTo="#fourthCommittee">[بناء على تقرير لجنة المسائل السياسية الخاصة وإنهاء الاستعمار (اللجنة الرابعة) (<inline name="originating document">A/80/537، الفقرة 15</inline>)]</docProponent>
      </p>
    </coverPage>
    <preface>
      <p>
        <docNumber>80/106</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">	اليوم الدولي لمناهضة الاستعمار بجميع أشكاله ومظاهره</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="bold italic">إن الجمعية العامة،</span>
        </p>
      </formula>
      <container name="إذ تؤكد من جديد" eId="container_2">
        <p xml:space="preserve">	<span class="bold italic">إذ تؤكد من جديد</span> مقاصد ميثاق الأمم المتحدة ومبادئه،</p>
      </container>
      <container name="وإذ تشير" eId="container_3">
        <p xml:space="preserve">	<span class="bold italic">وإذ تشير</span> إلى استمرار سريان أحكام قراراتها <a href="https://docs.un.org/ar/A/RES/1514(XV)">1514 (د-15)</a> المؤرخ 14 كانون الأول/ ديسمبر 1960 الذي يتضمن إعلان منح الاستقلال للبلدان والشعوب المستعمرة، و <a href="https://docs.un.org/ar/A/RES/1541(XV)">1541 (د-15)</a> المؤرخ 15 كانون الأول/ديسمبر 1960 الذي يتضمن المبادئ التي ينبغي أن تسترشد بها الدول الأعضاء في تقرير وجود أو عدم وجود الالتزام بإرسال المعلومات المنصوص عليها في المادة 73 (ه) من الميثاق، و <a href="https://docs.un.org/ar/A/RES/2625(XXV)">2625 (د-25)</a> المؤرخ 24 تشرين الأول/أكتوبر 1970 الذي يتضمن إعلان مبادئ القانون الدولي المتعلقة بالعلاقات الودية والتعاون بين الدول وفقاً لميثاق الأمم المتحدة، وإذ تشير إلى قراراتها بشأن العقد الدولي للقضاء على الاستعمار،</p>
      </container>
      <container name="وإذ تعرب عن القلق" eId="container_4">
        <p xml:space="preserve">	<span class="bold italic">وإذ تعرب عن القلق</span> من أنه على الرغم من مرور أكثر من 60 عاما على اعتماد إعلان منح الاستقلال للبلدان والشعوب المستعمرة، فإن الأحكام المضمنة فيه لم تنفذ تنفيذا كاملا،</p>
      </container>
      <container name="وإذ تسلّم" eId="container_5">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلّم</span> بضآلة ما يعرف عن فترة الاستعمار التي دامت 500 عام، وعن تجارة الرقيق عبر المحيط الأطلسي وعواقبها الدائمة التي يستشعرها الناس في العالم قاطبة، وإذ تدين الجرائم التي ارتكبت في الحقبة الاستعمارية إدانة شديدة،</p>
      </container>
      <container name="وإذ تؤكد من جديد" eId="container_6">
        <p xml:space="preserve">	<span class="bold italic">وإذ تؤكد من جديد</span> أن استمرار وجود الاستعمار بجميع أشكاله ومظاهره يتنافى مع ميثاق الأمم المتحدة وإعلان منح الاستقلال للبلدان والشعوب المستعمرة والإعلان العالمي لحقوق الإنسان<sup>(</sup><authorialNote marker="1" placement="bottom" eId="authorialNote_1"><p xml:space="preserve">	()	القرار 217 ألف (د-3).</p></authorialNote><sup>)</sup> ويحول دون تنمية التعاون الاقتصادي الدولي ويعيق التنمية الاجتماعية والثقافية والاقتصادية ويتعارض مع المثل الأعلى الذي ترومه الأمم المتحدة ألا وهو تحقق السلام العالمي،</p>
      </container>
      <container name="وإذ تلاحظ" eId="container_7">
        <p xml:space="preserve">	<span class="bold italic">وإذ تلاحظ</span> الممارسة الناشئة والاستعداد المتزايد لمعالجة الآثار المستمرة للاستعمار عبر جملة من الطرق تشمل اتخاذ مجموعة متعددة من التدابير وتنفيذ العدالة التعويضية بوسائل من ضمنها تقديم الاعتذارات الرسمية وإجراءات الكشف عن الحقيقة والمصالحة بأشكال مختلفة والسعي، حيثما لزم، إلى جبر الضرر،</p>
      </container>
      <container name="وإذ تسلّم" eId="container_8">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلّم</span> بأن القضاء على الاستعمار كان من أولويات الأمم المتحدة ولا يزال كذلك وخصوصا في سياق العقد الدولي الرابع للقضاء على الاستعمار،</p>
      </container>
      <container name="وإذ تعلن رسميا" eId="container_9">
        <p xml:space="preserve">	<span class="bold italic">وإذ تعلن رسميا</span> ضرورة التعجيل بوضع حد غير مشروط أو مقيد للاستعمار بجميع أشكاله ومظاهره، وإذ تؤكد من جديد تصميمها على تنفيذ إعلان منح الاستقلال للبلدان والشعوب المستعمرة وجميع قراراتها ومقرراتها اللاحقة، وعلى اتخاذ جميع الخطوات اللازمة في هذا الصدد،</p>
      </container>
      <container name="وإذ تؤكد من جديد" eId="container_10">
        <p xml:space="preserve">	<span class="bold italic">وإذ تؤكد من جديد</span> أن كل سعي يروم تقويض الوحدة الوطنية والسلامة الإقليمية لبلد ما، جزئيا أو كليا، أمر يتنافى ومقاصد ميثاق الأمم المتحدة ومبادئه،</p>
      </container>
      <container name="وإذ تحث" eId="container_11">
        <p xml:space="preserve">	<span class="bold italic">وإذ تحث</span> في هذا الصدد على التعجيل بالتنفيذ التام للقرارات والمقررات التي اتخذتها الجمعية العامة في هذا الشأن، وإذ تكرر تأكيد تصميم الأمم المتحدة والمجتمع الدولي على الوفاء بوعدهما تمكين الشعوب الخاضعة لهيمنة الأجنبي وسيطرته واستغلاله من التمتع بالمساواة في الحقوق ونيل الحرية والعدالة على نحو ما ينص عليه ميثاق الأمم المتحدة،</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_12" class="SingleTxt">
        <num>1 -</num>
        <content eId="para_12__content">
          <p xml:space="preserve">	<span class="bold italic">تقرر</span> أن تعلن 14 كانون الأول/ديسمبر اليوم الدولي لمناهضة الاستعمار بجميع أشكاله ومظاهره، انسجاما مع روح إعلان منح الاستقلال للبلدان والشعوب المستعمرة ونصه<sup>(</sup><authorialNote marker="2" placement="bottom" eId="authorialNote_2"><p xml:space="preserve">	()	القرار <a href="https://docs.un.org/ar/A/RES/1514(XV)">1514 (د-15)</a>.</p></authorialNote><sup>)</sup> ومع المبادئ المكرسة في ميثاق الأمم المتحدة، وأن يحتفل به سنويا ابتداء من عام 2025؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_13" class="SingleTxt">
        <num>2 -</num>
        <content eId="para_13__content">
          <p xml:space="preserve">	<span class="bold italic">تطلب</span> إلى الأمين العام أن يُطلِع جميع الدول الأعضاء ومؤسسات منظومة الأمم المتحدة والمنظمات الدولية والإقليمية الأخرى والمجتمع المدني على هذا القرار؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_15" class="SingleTxt">
        <num>3 -</num>
        <content eId="para_15__content">
          <p xml:space="preserve">	<span class="bold italic">تطلب</span> إلى الأمين العام أيضا أن يتخذ التدابير والترتيبات اللازمة لاحتفال الأمم المتحدة بهذا اليوم الدولي والترويج له؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_18" class="SingleTxt">
        <num>4 -</num>
        <content eId="para_18__content">
          <p xml:space="preserve">	<span class="bold italic">تدعو</span> جميع الدول الأعضاء والمراقبين لدى الأمم المتحدة ومؤسسات منظومة الأمم المتحدة والمنظمات الدولية والإقليمية الأخرى والمجتمع المدني إلى الاحتفال باليوم الدولي بالطريقة اللائقة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_22" class="SingleTxt">
        <num>5 -</num>
        <content eId="para_22__content">
          <p xml:space="preserve">	<span class="bold italic">تطلب</span> إلى رئيسة الجمعية العامة أن تنظم، في 18 كانون الأول/ديسمبر 2025، جلسة عامة رفيعة المستوى للجمعية العامة لمدة يوم واحد للاحتفال بالذكرى السنوية الخامسة والستين لإعلان منح الاستقلال للبلدان والشعوب المستعمرة، تشارك فيها الدول الأعضاء والمراقبون وكذلك رئيسة الجمعية العامة ورئيس المجلس الاقتصادي والاجتماعي والأمين العام، في إطار الأنشطة المقامة بمناسبة أول احتفال باليوم الدولي؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_27" class="SingleTxt">
        <num>6 -</num>
        <content eId="para_27__content">
          <p xml:space="preserve">	<span class="bold italic">تدعو</span> رئيسة الجمعية العامة أن تنظم في 14 كانون الأول/ديسمبر من كل عام، ما لم يصادف هذا التاريخ عطلة نهاية الأسبوع، جلسة عامة غير رسمية للجمعية العامة للاحتفال باليوم الدولي والترويج له، تشارك فيها الدول الأعضاء والمراقبون كما يشارك فيها كل من رئيسة الجمعية العامة ورئيس المجلس الاقتصادي والاجتماعي والأمين العام؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_33" class="SingleTxt">
        <num>7 -</num>
        <content eId="para_33__content">
          <p xml:space="preserve">	<span class="bold italic">تشدد</span> على ضرورة أن تُغطى تكاليف جميع الأنشطة التي قد تنشأ عن تنفيذ هذا القرار من التبرعات؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_40" class="SingleTxt">
        <num>8 -</num>
        <content eId="para_40__content">
          <p xml:space="preserve">	<span class="bold italic">تقرر</span> أن تدرج في جدول اﻷعمال المؤقت لدورتها الحادية والثمانين البند المعنون ”القضاء على اﻻستعمار بجميع أشكاله ومظاهره“ وأن تنظر فيه سنويا بعد ذلك، من أجل مواصلة النهوض بالمناقشات المتعلقة بهذا الموضوع.</p>
        </content>
      </paragraph>
    </mainBody>
