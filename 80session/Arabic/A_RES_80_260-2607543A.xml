    <preface>
      <p>
        <docNumber>80/260</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">	تعزيز التعاون والتكامل الاقتصادي على الصعيد الإقليمي من أجل ضمان التنمية المستدامة في منطقة وسط آسيا</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="bold italic">إن الجمعية العامة</span>،</p>
      </formula>
      <container name="إذ تسترشد" eId="container_2">
        <p xml:space="preserve">	<span class="bold italic">إذ تسترشد</span> بأحكام ميثاق الأمم المتحدة التي تشجع على اتخاذ تدابير للتعاون على الصعيد الإقليمي من أجل النهوض بمقاصد الأمم المتحدة ومبادئها،</p>
      </container>
      <container name="وإذ تسلم" eId="container_3">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلم</span> بأهمية الدور الذي تضطلع به بلدان وسط آسيا في ضمان السلام والاستقرار والتنمية المستدامة في المنطقة، وكذلك في تشجيع التعاون على الصعيدين الإقليمي والدولي،</p>
      </container>
      <container name="وإذ تشير" eId="container_4">
        <p xml:space="preserve">	<span class="bold italic">وإذ تشير</span> إلى قراراتها <a href="https://undocs.org/ar/A/RES/72/283">72/283</a> المؤرخ 22 حزيران/يونيه 2018 بشأن تعزيز التعاون الإقليمي والدولي من أجل ضمان السلام والاستقرار والتنمية المستدامة في منطقة وسط آسيا، و <a href="https://undocs.org/ar/A/RES/74/214">74/214</a> المؤرخ 19 كانون الأول/ديسمبر 2019 بشأن السياحة المستدامة والتنمية المستدامة في وسط آسيا، و <a href="https://undocs.org/ar/A/RES/77/273">77/273</a> المؤرخ 24 شباط/فبراير 2023 بشأن دور مركز الأمم المتحدة الإقليمي للدبلوماسية الوقائية لمنطقة وسط آسيا، و <a href="https://undocs.org/ar/A/RES/78/9">78/9</a> المؤرخ 20 تشرين الثاني/نوفمبر 2023 بشأن الاحتفال بالذكرى السنوية الخامسة والعشرين لإنشاء برنامج الأمم المتحدة الخاص المعني باقتصادات وسط آسيا، و <a href="https://undocs.org/ar/A/RES/78/147">78/147</a> المؤرخ 19 كانون الأول/ ديسمبر 2023 بشأن التحديات البيئية التي تواجهها منطقة وسط آسيا: تعزيز التضامن الإقليمي من أجل تحقيق التنمية المستدامة والرخاء، و <a href="https://undocs.org/ar/A/RES/78/284">78/284</a> المؤرخ 4 حزيران/يونيه 2024 بشأن توحيد العزم والتعاون في وسط آسيا على التصدي للتحديات المتصلة بالمخدرات ومواجهتها على نحو فعال، و <a href="https://docs.un.org/ar/A/RES/79/5">79/5</a> المؤرخ 24 تشرين الأول/أكتوبر 2024 بشأن منطقة السلام والثقة والتعاون في وسط آسيا، و <a href="https://docs.un.org/ar/A/RES/79/268">79/268</a> المؤرخ 4 آذار/مارس 2025 بشأن مركز الأمم المتحدة الإقليمي لأهداف التنمية المستدامة لوسط آسيا وأفغانستان، و <a href="https://docs.un.org/ar/A/RES/79/322">79/322</a> المؤرخ 25 تموز/يوليه 2025 بشأن دور الذكاء الاصطناعي في تهيئة فرص جديدة للتنمية المستدامة في وسط آسيا،</p>
      </container>
      <container name="وإذ ترحب" eId="container_5">
        <p xml:space="preserve">	<span class="bold italic">وإذ ترحب</span> بتزايد التعاون الثنائي والإقليمي فيما بين بلدان المنطقة على جميع المستويات من أجل خلق الدينامية في وسط آسيا وإعادة تنشيط المنطقة، مما يتيح فرصا جديدة لمشاركة الأمم المتحدة،</p>
      </container>
      <container name="وإذ تؤكد من جديد" eId="container_6">
        <p xml:space="preserve">	<span class="bold italic">وإذ تؤكد من جديد</span> أهمية عقد اجتماعات تشاورية منتظمة لرؤساء دول وسط آسيا، وإذ تحيط علما في هذا الصدد بالاجتماعات التشاورية التي عُقدت في أستانا في 15 آذار/مارس 2018، وطشقند في 29 تشرين الثاني/نوفمبر 2019، وأوازا في 6 آب/أغسطس 2021، وشولبون - آتا في 21 تموز/ يوليه 2022، ودوشانبه في 14 أيلول/سبتمبر 2023، وأستانا في 9 آب/أغسطس 2024، وبالاجتماع التشاوري السابع الذي عقد في طشقند في 16 تشرين الثاني/نوفمبر 2025،</p>
      </container>
      <container name="وإذ تسلم" eId="container_7">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلم</span> بالإمكانيات الكبيرة للتكامل الاقتصادي والترابط على الصعيد الإقليمي في تعزيز النمو الشامل والتنمية المستدامة، وإذ تلاحظ مع الارتياح التقدم المحرز في بلدان وسط آسيا، واندماجها في اقتصادات أوروبا وآسيا، ومساهمتها في النمو الاقتصادي العالمي،</p>
      </container>
      <container name="وإذ تلاحظ" eId="container_8">
        <p xml:space="preserve">	<span class="bold italic">وإذ تلاحظ</span> أهمية تعزيز الشراكات الصناعية والروابط الاقتصادية بين المؤسسات الصغيرة والمتوسطة الحجم في دول وسط آسيا من أجل تحفيز الابتكار وتوفير فرص للعمل وضمان النمو المستدام على المدى الطويل في جميع أنحاء المنطقة،</p>
      </container>
      <container name="وإذ تسلم" eId="container_9">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلم</span> بالمصالح المشتركة المتولّدة عن مواصلة تطوير التعاون الإقليمي فيما بين بلدان وسط آسيا من أجل تحقيق أهداف التنمية المستدامة والنهوض بعلاقات حسن الجوار،</p>
      </container>
      <container name="وإذ تسلم أيضا" eId="container_10">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلم أيضا</span> بأهمية الدبلوماسية الوقائية، وإذ تلاحظ في هذا السياق الدور الذي يضطلع به مركز الأمم المتحدة الإقليمي للدبلوماسية الوقائية لمنطقة وسط آسيا،</p>
      </container>
      <container name="وإذ تسلم كذلك" eId="container_11">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلم كذلك</span> بالجهود التي يبذلها برنامج الأمم المتحدة الخاص المعني باقتصادات وسط آسيا،</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_12" class="MercuryDocument">
        <num>1 -</num>
        <content eId="para_12__content">
          <p xml:space="preserve">	<span class="bold italic">تلاحظ مع الارتياح</span> ما تقدمه دول وسط آسيا من مساهمة عملية قيِّمة وما تبذله من جهود في سبيل توطيد التعاون الإقليمي والتكامل الاقتصادي في وسط آسيا، فضلا عن تعزيز التنمية المستدامة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_13" class="MercuryDocument">
        <num>2 -</num>
        <content eId="para_13__content">
          <p xml:space="preserve">	<span class="bold italic">تعرب عن دعمها</span> للجهود والمبادرات الإقليمية الجارية الرامية إلى توطيد التعاون الإقليمي والتكامل الاقتصادي في وسط آسيا؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_15" class="MercuryDocument">
        <num>3 -</num>
        <content eId="para_15__content">
          <p xml:space="preserve">	<span class="bold italic">تؤكد من جديد</span> أن الأخطار التي تهدد الاستقرار والتنمية المستدامة في المنطقة تتطلب توثيق التعاون وزيادة تنسيقه فيما بين دول وسط آسيا، وكذلك بين هذه الدول والمنظمات الدولية والإقليمية، وتؤكد من جديد أيضا أهمية التعاون الإقليمي بمشاركة المنظمات الإقليمية والدولية في التصدي لهذه الأخطار؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_18" class="MercuryDocument">
        <num>4 -</num>
        <content eId="para_18__content">
          <p xml:space="preserve">	<span class="bold italic">تهيب</span> ببلدان المنطقة أن تواصل استخدام المنبر المخصص لإجراء مشاورات منتظمة بين رؤساء الدول وغيره من المحافل بفعالية لتشجيع التكامل الاقتصادي في المنطقة وخارجها؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_22" class="MercuryDocument">
        <num>5 -</num>
        <content eId="para_22__content">
          <p xml:space="preserve">	<span class="bold italic">تهيب</span> بالدول الأعضاء أن تدعم الجهود التي تبذلها دول وسط آسيا بهدف توطيد التكامل الاقتصادي؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_27" class="MercuryDocument">
        <num>6 -</num>
        <content eId="para_27__content">
          <p xml:space="preserve">	<span class="bold italic">تؤيد</span> زيادة توطيد علاقات حسن الجوار والصداقة بين دول وسط آسيا؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_33" class="MercuryDocument">
        <num>7 -</num>
        <content eId="para_33__content">
          <p xml:space="preserve">	<span class="bold italic">تلاحظ</span> أهمية تعميق التكامل الاقتصادي والترابط الشامل في منطقة وسط آسيا، والاستفادة الكاملة من الإمكانات الجماعية للمنطقة باعتبار ذلك شرطا لازما من شروط التنمية المستدامة وحرية تنقل الأشخاص والسلع والخدمات؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_40" class="MercuryDocument">
        <num>8 -</num>
        <content eId="para_40__content">
          <p xml:space="preserve">	<span class="bold italic">تؤيد</span> مواصلة تطوير التعاون الصناعي والروابط الاقتصادية بين المؤسسات الصغيرة والمتوسطة الحجم في دول وسط آسيا طوعًا وبما يعود بالمنفعة على جميع الأطراف، بطرق منها تبادل أفضل الممارسات واستكشاف مبادرات مشتركة في القطاعات موضع الاهتمام المشترك من أجل تحسين قدرة الاقتصاد الإقليمي على الصمود؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_48" class="MercuryDocument">
        <num>9 -</num>
        <content eId="para_48__content">
          <p xml:space="preserve">	<span class="bold italic">تهيب</span> بالوكالات المتخصصة والصناديق والبرامج التابعة لمنظومة الأمم المتحدة مواءمة برامجها وأنشطتها بما يدعم أولويات التعاون الإقليمي والتكامل الاقتصادي والتنمية المستدامة في وسط آسيا، على النحو الذي تحدده بلدان المنطقة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_57" class="MercuryDocument">
        <num>10 -</num>
        <content eId="para_57__content">
          <p xml:space="preserve">	<span class="bold italic">تشجع</span> الجهود التي يبذلها شركاء دول وسط آسيا والمجتمع الدولي ككل من أجل تعزيز وتوسيع نطاق التعاون مع بلدان المنطقة.</p>
        </content>
      </paragraph>
    </mainBody>
