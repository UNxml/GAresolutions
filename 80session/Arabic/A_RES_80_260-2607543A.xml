      <p>
        <inline name="agenda item name">التنمية المستدامة</inline>
      </p>
      <p>
        <docTitle>قرار اتخذته الجمعية العامة في 20 أيار/مايو 2026</docTitle>
      </p>
      <p xml:space="preserve">
        <docProponent refersTo="#noMainCommittee">[دون الإحالة إلى لجنة رئيسية (<inline name="originating document">A/80/L.52</inline>)]</docProponent>
      </p>
