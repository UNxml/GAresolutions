    <preface>
      <p>
        <docNumber>80/262</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">	دور سياسة الحياد وأهميتها في صون وتعزيز السلام والأمن والتنمية المستدامة على الصعيد الدولي</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="bold italic">إن الجمعية العامة</span>،</p>
      </formula>
      <container name="إذ تشير" eId="container_2">
        <p xml:space="preserve">	<span class="bold italic">إذ تشير</span> إلى قراراتها ذات الصلة بسياسة الحياد، بما فيها القرارات <a href="https://docs.un.org/ar/A/RES/50/80">50/80</a> ألف المؤرخ 12 كانون الأول/ديسمبر 1995 و <a href="https://docs.un.org/ar/A/RES/69/285">69/285</a> المؤرخ 3 حزيران/يونيه 2015 و <a href="https://docs.un.org/ar/A/RES/71/275">71/275</a> المؤرخ 2 شباط/فبراير 2017 و <a href="https://docs.un.org/ar/A/RES/75/28">75/28</a> المؤرخ 7 كانون الأول/ديسمبر 2020 و <a href="https://docs.un.org/ar/A/RES/79/274">79/274</a> المؤرخ 21 آذار/مارس 2025،</p>
      </container>
      <container name="وإذ تسترشد" eId="container_3">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسترشد</span> بمقاصد ميثاق الأمم المتحدة ومبادئه،</p>
      </container>
      <container name="وإذ تحتفل" eId="container_4">
          <p xml:space="preserve">	<span class="bold italic">وإذ تحتفل</span> بالذكرى السنوية الثمانين لإنشاء الأمم المتحدة، وإذ تقر بالحاجة الماسّة إلى تشجيع تعددية الأطراف وتعزيزها وبأن الأمم المتحدة تضطلع بدور محوري في هذا الصدد،</p>
      </container>
      <container name="وإذ تشير" eId="container_5">
        <p xml:space="preserve">	<span class="bold italic">وإذ تشير</span> إلى الوثيقتين الختاميتين لمؤتمر عشق آباد لعامي 2015<sup>(</sup><authorialNote marker="1" placement="bottom" eId="authorialNote_1"><p xml:space="preserve">	()	<a href="https://docs.un.org/ar/A/70/652">A/70/652-S/2016/20</a>، المرفق.</p></authorialNote><sup>)</sup> و 2020<sup>(</sup><authorialNote marker="2" placement="bottom" eId="authorialNote_2"><p xml:space="preserve">	()	<a href="https://docs.un.org/ar/A/75/651">A/75/651-S/2020/1203</a>، المرفق.</p></authorialNote><sup>)</sup>، وإذ تنوه بالجهود التي تبذلها حكومة تركمانستان لإضفاء الطابع المؤسسي على الحوار بشأن الحياد والدبلوماسية الوقائية والسلام، بما يتماشى مع مبادئ ومقاصد ميثاق الأمم المتحدة،</p>
      </container>
      <container name="وإذ تلاحظ" eId="container_6">
        <p xml:space="preserve">	<span class="bold italic">وإذ تلاحظ</span> القرارات ذات الصلة الصادرة عن مجلس وزراء خارجية الدول الأعضاء في منظمة التعاون الإسلامي التي تشدد على دور سياسة الحياد في صون وتعزيز السلام والأمن والتنمية المستدامة على الصعيد الدولي،</p>
      </container>
      <container name="وإذ تشدد" eId="container_7">
        <p xml:space="preserve">	<span class="bold italic">وإذ تشدد</span> على أن سياسات الحياد الوطنية التي ينتهجها بعض الدول، دون المساس بحقوق الدول والتزاماتها بموجب ميثاق الأمم المتحدة، يمكن أن تسهم في تعزيز السلام والأمن الدوليين في المناطق المعنية وعلى الصعيد العالمي ويمكن أن تؤدي دوراً هاما في إقامة علاقات سلمية وودية تخدم المصالح المتبادلة بين بلدان العالم،</p>
      </container>
      <container name="وإذ تسلم" eId="container_8">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلم</span> بأن سياسات الحياد الوطنية المشار إليها تستهدف تعزيز استخدام الدبلوماسية الوقائية، بسبل من قبيل منع نشوب النزاع، والوساطة، والمساعي الحميدة، والتفاوض، والاستعانة بالمبعوثين الخاصين، والمشاورات غير الرسمية، وبناء السلام، وأنشطة التنمية المحددة الهدف،</p>
      </container>
      <container name="وإذ تسلم أيضا" eId="container_9">
        <p xml:space="preserve">	<span class="bold italic">وإذ تسلم أيضا</span> بالدور الإيجابي الذي يمكن أن تؤديه البلدان المحايدة في تقديم المساعدة الإنسانية وإيصالها في حالات الطوارئ المعقدة والكوارث الطبيعية، وفقا لأحكام قرار الجمعية العامة <a href="https://docs.un.org/ar/A/RES/46/182">46/182</a> المؤرخ 19 كانون الأول/ديسمبر 1991 بشأن تعزيز تنسيق المساعدة الإنسانية التي تقدمها الأمم المتحدة في حالات الطوارئ ومرفق ذلك القرار، بما في ذلك مبادئ العمل الإنساني المتمثلة في الإنسانية والحياد والنزاهة والاستقلال، وقرارات الجمعية العامة ذات الصلة بالموضوع، بما في ذلك قرارها <a href="https://docs.un.org/ar/A/RES/79/140">79/140</a> المؤرخ 9 كانون الأول/ديسمبر 2024، وكذلك قرارات المجلس الاقتصادي والاجتماعي ذات الصلة واستنتاجاته المتفق عليها،</p>
      </container>
      <container name="وإذ تؤكد" eId="container_10">
        <p xml:space="preserve">	<span class="bold italic">وإذ تؤكد</span> على أن سياسات الحياد يمكن أن تسهم في تعزيز السلام والأمن، وفي تقوية التعاون والترابط على المستويات دون الإقليمية والإقليمية والدولية، بما في ذلك في المجالات الاقتصادية والاجتماعية والإنسانية،</p>
      </container>
      <container name="وإذ تلاحظ" eId="container_11">
        <p xml:space="preserve">	<span class="bold italic">وإذ تلاحظ</span> عمل مجموعة أصدقاء الحياد من أجل السلام والأمن والتنمية المستدامة، وهي مجموعة غير رسمية أنشئت بمبادرة من تركمانستان في آب/أغسطس 2020 وتعمل استنادا إلى الإعلان النهائي للاجتماع الوزاري الأول للمجموعة<sup>(</sup><authorialNote marker="3" placement="bottom" eId="authorialNote_3"><p xml:space="preserve">	()	<a href="https://docs.un.org/ar/A/77/778">A/77/778</a>، المرفق.</p></authorialNote><sup>)</sup> من أجل الاستمرار في التحاور على مستوى واسع متعدد الأطراف بشأن التنفيذ العملي لمبادئ الحياد في منع نشوب النزاعات، وتبديد الأسباب الجذرية للنزاعات وعواقبها، وحل التحديات الإنسانية، وتعزيز الحياد في العلاقات الدولية؛</p>
      </container>
      <container name="وإذ تقرّ" eId="container_12">
        <p xml:space="preserve">	<span class="bold italic">وإذ تقرّ</span> بالدور الريادي الذي تضطلع به تركمانستان، التي عملت، من خلال سياستها للحياد الدائم، على تعزيز الحوار والسلام وتدابير الثقة وبناء الثقة في العلاقات الدولية، بما في ذلك من خلال السنة الدولية للحوار كضمان للسلام، 2023، والسنتين الدوليتين للسلام والثقة، اللتين أعلنتهما الجمعية العامة،</p>
      </container>
      <container name="وإذ تؤكد" eId="container_13">
        <p xml:space="preserve">	<span class="bold italic">وإذ تؤكد</span> في هذا الصدد على عقد المنتدى الدولي والمكرَّس للسنة الدولية للسلام والثقة، 2025، ولليوم الدولي للحياد، وللذكرى الثلاثين للحياد الدائم لتركمانستان، المعقود في عشق أباد في 12 كانون الأول/ديسمبر 2025، وإذ تلاحظ اعتماد وثيقته الختامية، إعلان عشق أباد<sup>(</sup><authorialNote marker="4" placement="bottom" eId="authorialNote_4"><p xml:space="preserve">	()	<a href="https://docs.un.org/ar/A/80/578">A/80/578-S/2025/833</a>، المرفق.</p></authorialNote><sup>)</sup>، الذي يؤكد على أهمية سياسة الحياد كأداة فعالة لتعزيز السلام والثقة والتنمية المستدامة،</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_14" class="SingleTxt">
        <num>1 -</num>
        <content eId="para_14__content">
          <p xml:space="preserve">	<span class="bold italic">تقر</span> بأن الحياد، دون المساس بحقوق الدول والتزاماتها بموجب ميثاق الأمم المتحدة، يمكن أن يجسد المسؤولية لا اللامبالاة، معبراً عن التزام مبدئي بمنع نشوب النزاعات من خلال النزاهة والمساعي الحميدة والوساطة وبناء الثقة، مع الحفاظ في الوقت نفسه على المشاركة البناءة مع جميع الأطراف من أجل تحقيق السلام والأمن الدوليين؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_15" class="SingleTxt">
        <num>2 -</num>
        <content eId="para_15__content">
          <p xml:space="preserve">	<span class="bold italic">تدعو</span> الأمين العام إلى التعاون الوثيق مع الدول المحايدة، بغية تنفيذ مبادئ الدبلوماسية الوقائية والاهتداء بتلك المبادئ في ما تضطلع به من أنشطة الوساطة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_17" class="SingleTxt">
        <num>3 -</num>
        <content eId="para_17__content">
          <p xml:space="preserve">	<span class="bold italic">توصي</span> جميع الدول الأعضاء ومؤسسات منظومة الأمم المتحدة وسائر المنظمات الدولية والإقليمية ودون الإقليمية بالاستعانة، حسب الاقتضاء، بكل ما تتيحه الدول المحايدة وجهود الوساطة من إمكانات في تسوية المنازعات بالوسائل السلمية ومنع نشوب النزاعات وحلها وفقا لميثاق الأمم المتحدة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_20" class="SingleTxt">
        <num>4 -</num>
        <content eId="para_20__content">
          <p xml:space="preserve">	<span class="bold italic">تدعو مرة أخرى</span> جميع الدول الأعضاء ومؤسسات منظومة الأمم المتحدة وسائر المنظمات الدولية والإقليمية، وكذلك المنظمات غير الحكومية والأفراد، إلى الاحتفال سنويا باليوم الدولي للحياد في 12 كانون الأول/ديسمبر عن طريق التثقيف وعقد مناسبات تهدف إلى تعزيز معرفة الجمهور بدور سياسة الحياد في صون وتعزيز السلام والأمن الدوليين؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_24" class="SingleTxt">
        <num>5 -</num>
        <content eId="para_24__content">
          <p xml:space="preserve">	<span class="bold italic">تكرر </span>دعوة الأمين العام إلى التماس آراء الدول الأعضاء والكيانات المعنية في منظومة الأمم المتحدة بشأن دور سياسة الحياد وأهميتها في صون وتعزيز السلام والأمن الدوليين، وموافاة الجمعية العامة بهذه الآراء في دورتها الحادية والثمانين لمواصلة النظر فيها؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_29" class="SingleTxt">
        <num>6 -</num>
        <content eId="para_29__content">
          <p xml:space="preserve">	<span class="bold italic">ترحب</span> باقتراح تركمانستان، بالتعاون مع جامعة السلام ومركز الأمم المتحدة الإقليمي للدبلوماسية الوقائية لمنطقة وسط آسيا، استكشاف إمكانية إنشاء واستضافة مركز أكاديمي لدراسات السلام والحياد والدبلوماسية الوقائية، من خلال التبرعات، وتدعو الدول الأعضاء وكيانات الأمم المتحدة ذات الصلة، حسب الاقتضاء، إلى النظر في سبل دعم هذه المبادرة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_35" class="SingleTxt">
        <num>7 -</num>
        <content eId="para_35__content">
          <p xml:space="preserve">	<span class="bold italic">تشجع</span> الاستخدام الفعال لأراضي البلدان المحايدة لاستضافة محادثات السلام وعمليات حل النزاعات وتسويتها، بأساليب تشمل إنشاء مرافق مخصصة للوساطة، وتلاحظ اقتراح تركمانستان إنشاء غرفة الوساطة للسلام على أراضيها، وفقا لميثاق الأمم المتحدة، وهو ما سيتطلب تقييما تجريه الدول الأعضاء ومنظومة الأمم المتحدة، على النحو الذي أكد عليه قرار الجمعية العامة <a href="https://docs.un.org/ar/A/RES/79/274">79/274</a>، دون المساس بولايات الأمم المتحدة القائمة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_42" class="SingleTxt">
        <num>8 -</num>
        <content eId="para_42__content">
          <p xml:space="preserve">	<span class="bold italic">تكرر</span> طلبها إلى الأمين العام أن يضع، في حدود الموارد المتاحة، وبقيادة جميع الدول الأعضاء في الأمم المتحدة، توجيهات لدعم وتنفيذ مبادئ الحياد من أجل السلام والأمن، مع التركيز بشكل خاص على توحيد الدروس المستفادة والمبادئ الأساسية للتطبيق الفعال للحياد في العلاقات الدولية؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_50" class="SingleTxt">
        <num>9 -</num>
        <content eId="para_50__content">
          <p xml:space="preserve">	<span class="bold italic">تدعو</span> الدول الأعضاء في الأمم المتحدة، وحركة بلدان عدم الانحياز، والمنظمات الإقليمية والدولية الأخرى إلى مواصلة بلورة مفهوم الأمن العالمي القائم على الحياد، تحت رعاية الأمم المتحدة، كأساس لبناء توافق الآراء وتعزيز التعاون المتعدد الأطراف، مسترشدة بالمبادئ والمقاصد المكرسة في ميثاق الأمم المتحدة.</p>
        </content>
      </paragraph>
