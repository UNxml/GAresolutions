    <preface>
      <p>
        <docNumber>80/261.</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">	Peaceful settlement of border disputes</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="italic">The General Assembly</span>,</p>
      </formula>
      <container name="Recalling" eId="container_2">
        <p xml:space="preserve">	<span class="italic">Recalling</span> the purposes and principles of the Charter of the United Nations, in particular the obligation of States to settle their international disputes by peaceful means in such a manner that international peace and security and justice are not endangered,</p>
      </container>
      <container name="Reaffirming" eId="container_3">
        <p xml:space="preserve">	<span class="italic">Reaffirming</span> the principles of sovereign equality of States, territorial integrity, political independence, the prohibition of the threat or use of force, and the principle that nothing in the Charter of the United Nations authorizes the United Nations to intervene in matters which are essentially within the domestic jurisdiction of any State, in accordance with the Charter of the United Nations and the Declaration on Principles of International Law concerning Friendly Relations and Cooperation among States in accordance with the Charter of the United Nations,<authorialNote marker="1" placement="bottom" eId="authorialNote_1"><p xml:space="preserve">		Resolution <a href="https://docs.un.org/en/A/RES/2625(XXV)">2625 (XXV)</a>, annex.</p></authorialNote></p>
      </container>
      <container name="Recalling" eId="container_4">
        <p xml:space="preserve">	<span class="italic">Recalling</span> the Manila Declaration on the Peaceful Settlement of International Disputes,<authorialNote marker="2" placement="bottom" eId="authorialNote_2"><p xml:space="preserve">		Resolution <a href="https://docs.un.org/en/A/RES/37/10">37/10</a>, annex.</p></authorialNote> which affirms the free choice of means for the peaceful settlement of disputes in conformity with the Charter of the United Nations and international law,</p>
      </container>
      <container name="Recalling also" eId="container_5">
        <p xml:space="preserve">	<span class="italic">Recalling also</span> its relevant resolutions on the peaceful settlement of international disputes, including resolution <a href="https://docs.un.org/en/A/RES/3283(XXIX)">3283 (XXIX)</a> of 12 December 1974,</p>
      </container>
      <container name="Noting" eId="container_6">
        <p xml:space="preserve">	<span class="italic">Noting</span> that the peaceful settlement of border disputes contributes to the maintenance of international peace and security and to the strengthening of friendly relations and good-neighbourliness among States,</p>
      </container>
      <container name="Welcoming" eId="container_7">
        <p xml:space="preserve">	<span class="italic">Welcoming</span> efforts by Member States in resolving border disputes through peaceful means and by mutual agreement, including countries of Central Asia, in particular Kyrgyzstan, Tajikistan and Uzbekistan,</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_8" class="MercuryDocument">
        <num>1.</num>
        <content eId="para_8__content">
          <p xml:space="preserve">	<span class="italic">Welcomes</span> the efforts of Member States to resolve border disputes by peaceful means, and stresses the importance of dialogue and international cooperation among Member States in achieving lasting and mutually acceptable solutions consistent with the purposes and principles of the Charter of the United Nations;</p>
        </content>
      </paragraph>
      <paragraph eId="para_9" class="MercuryDocument">
        <num>2.</num>
        <content eId="para_9__content">
          <p xml:space="preserve">	<span class="italic">Recalls</span> that the peaceful settlement of border disputes is to be carried out in conformity with the Charter of the United Nations and international law obligations, based on the sovereign equality of States, the consent of the States parties to the dispute and due regard for their rights and legitimate interests, and urges all parties to refrain from any action that may aggravate or extend such disputes;</p>
        </content>
      </paragraph>
      <paragraph eId="para_11" class="MercuryDocument">
        <num>3.</num>
        <content eId="para_11__content">
          <p xml:space="preserve">	<span class="italic">Encourages</span> Member States, where appropriate, to make use of the peaceful means of dispute settlement, as provided for in the Charter of the United Nations and international law, including through dialogue, negotiation and other mutually agreed peaceful means.</p>
        </content>
      </paragraph>
    </mainBody>
