    <preface>
      <p>
        <docNumber>80/260.</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">	Strengthening regional cooperation and economic integration to ensure sustainable development in the Central Asian region</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="italic">The General Assembly</span>,</p>
      </formula>
      <container name="Guided" eId="container_2">
        <p xml:space="preserve">	<span class="italic">Guided </span>by the provisions of the Charter of the United Nations that encourage measures for regional cooperation to advance the purposes and principles of the United Nations,</p>
      </container>
      <container name="Recognizing" eId="container_3">
        <p xml:space="preserve">	<span class="italic">Recognizing</span> the important role of the Central Asian countries in ensuring peace, stability and sustainable development in the region as well as in promoting regional and international cooperation,</p>
      </container>
      <container name="Noting" eId="container_4">
        <p xml:space="preserve">	<span class="italic">Noting </span>its resolutions <a href="https://docs.un.org/en/A/RES/72/283">72/283</a> of 22 June 2018 on strengthening regional and international cooperation to ensure peace, stability and sustainable development in the Central Asian region, <a href="https://docs.un.org/en/A/RES/74/214">74/214</a> of 19 December 2019 on sustainable tourism and sustainable development in Central Asia, <a href="https://docs.un.org/en/A/RES/77/273">77/273</a> of 24 February 2023 on the role of the United Nations Regional Centre for Preventive Diplomacy for Central Asia, <a href="https://docs.un.org/en/A/RES/78/9">78/9</a> of 20 November 2023 on the commemoration of the twenty-fifth anniversary of the United Nations Special Programme for the Economies of Central Asia, <a href="https://docs.un.org/en/A/RES/78/147">78/147</a> of 19 December 2023 on Central Asia facing environmental challenges: fostering regional solidarity for sustainable development and prosperity, <a href="https://docs.un.org/en/A/RES/78/284">78/284</a> of 4 June 2024 on Central Asia’s unified resolve and cooperation to effectively address and counter drug-related challenges, <a href="https://docs.un.org/en/A/RES/79/5">79/5</a> of 24 October 2024 on the zone of peace, trust and cooperation of Central Asia, <a href="https://docs.un.org/en/A/RES/79/268">79/268</a> of 4 March 2025 on the United Nations Regional Centre for the Sustainable Development Goals for Central Asia and Afghanistan and <a href="https://docs.un.org/en/A/RES/79/322">79/322</a> of 25 July 2025 on the role of artificial intelligence in creating new opportunities for sustainable development in Central Asia,</p>
      </container>
      <container name="Welcoming" eId="container_5">
        <p xml:space="preserve">	<span class="italic">Welcoming </span>the increasing bilateral and regional cooperation among the countries of the region at all levels towards creating a dynamic and reinvigorated Central Asia, which provides new opportunities for United Nations engagement,</p>
      </container>
      <container name="Reaffirming" eId="container_6">
        <p xml:space="preserve">	<span class="italic">Reaffirming</span> the importance of holding regular consultative meetings of the Central Asian Heads of State, and in this regard taking note of the consultative meetings held in Astana on 15 March 2018, Tashkent on 29 November 2019, Awaza on 6 August 2021, Cholpon-Ata on 21 July 2022, Dushanbe on 14 September 2023, Astana on 9 August 2024 and the seventh consultative meeting, held in Tashkent on 16 November 2025,</p>
      </container>
      <container name="Recognizing" eId="container_7">
        <p xml:space="preserve">	<span class="italic">Recognizing</span> the significant potential of regional economic integration and interconnectivity to promote inclusive growth and sustainable development, and noting with satisfaction the progress made in the countries of Central Asia, their integration into the economies of Europe and Asia and their contribution to global economic growth,</p>
      </container>
      <container name="Noting" eId="container_8">
        <p xml:space="preserve">	<span class="italic">Noting</span> the importance of fostering industrial partnerships and economic ties between small and medium-sized enterprises of the Central Asian States to stimulate innovation, create jobs and ensure long-term sustainable growth across the region,</p>
      </container>
      <container name="Recognizing" eId="container_9">
        <p xml:space="preserve">	<span class="italic">Recognizing </span>shared interests in the further development of regional cooperation among the Central Asian countries for achieving the Sustainable Development Goals and advancing good-neighbourly relations,</p>
      </container>
      <container name="Recognizing also" eId="container_10">
        <p xml:space="preserve">	<span class="italic">Recognizing also</span> the importance of preventive diplomacy, and noting in this context the role of the United Nations Regional Centre for Preventive Diplomacy for Central Asia,</p>
      </container>
      <container name="Recognizing further" eId="container_11">
        <p xml:space="preserve">	<span class="italic">Recognizing further</span> the efforts of the United Nations Special Programme for the Economies of Central Asia,</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_12" class="MercuryDocument">
        <num>1.</num>
        <content eId="para_12__content">
          <p xml:space="preserve">	<span class="italic">Notes with satisfaction</span> the significant practical contribution and efforts of the Central Asian States in strengthening regional cooperation and economic integration in Central Asia, as well as in fostering sustainable development;</p>
        </content>
      </paragraph>
      <paragraph eId="para_13" class="MercuryDocument">
        <num>2.</num>
        <content eId="para_13__content">
          <p xml:space="preserve">	<span class="italic">Expresses its support </span>for the ongoing regional efforts and initiatives to strengthen regional cooperation and economic integration in Central Asia;</p>
        </content>
      </paragraph>
      <paragraph eId="para_15" class="MercuryDocument">
        <num>3.</num>
        <content eId="para_15__content">
          <p xml:space="preserve">	<span class="italic">Reaffirms </span>that threats to stability and sustainable development in the region require closer and more coordinated cooperation between the States of Central Asia, as well as between them and international and regional organizations, and also reaffirms the importance of regional cooperation involving regional and international organizations in addressing these threats;</p>
        </content>
      </paragraph>
      <paragraph eId="para_18" class="MercuryDocument">
        <num>4.</num>
        <content eId="para_18__content">
          <p xml:space="preserve">	<span class="italic">Calls upon</span> the countries of the region to further make effective use of the platform of regular consultations of Heads of State and other forums to promote economic integration in the region and beyond;</p>
        </content>
      </paragraph>
      <paragraph eId="para_22" class="MercuryDocument">
        <num>5.</num>
        <content eId="para_22__content">
          <p xml:space="preserve">	<span class="italic">Calls upon</span> Member States to support the efforts of the Central Asian States aimed at strengthening economic integration;</p>
        </content>
      </paragraph>
      <paragraph eId="para_27" class="MercuryDocument">
        <num>6.</num>
        <content eId="para_27__content">
          <p xml:space="preserve">	<span class="italic">Supports</span> the further strengthening of good-neighbourly and friendly relations among the Central Asian States;</p>
        </content>
      </paragraph>
      <paragraph eId="para_33" class="MercuryDocument">
        <num>7.</num>
        <content eId="para_33__content">
          <p xml:space="preserve">	<span class="italic">Notes</span> the importance of deepening economic integration and comprehensive connectivity in Central Asia, and making full use of the region’s collective potential as a necessary condition for sustainable development and the free movement of people, goods and services;</p>
        </content>
      </paragraph>
      <paragraph eId="para_40" class="MercuryDocument">
        <num>8.</num>
        <content eId="para_40__content">
          <p xml:space="preserve">	<span class="italic">Supports</span> the further development of industrial cooperation and economic ties of small and medium-sized enterprises among Central Asian States on a voluntary and mutually beneficial basis, including through the exchange of best practices and the exploration of joint initiatives in sectors of common interest to enhance regional economic resilience;</p>
        </content>
      </paragraph>
      <paragraph eId="para_48" class="MercuryDocument">
        <num>9.</num>
        <content eId="para_48__content">
          <p xml:space="preserve">	<span class="italic">Calls upon</span> the specialized agencies, funds and programmes of the United Nations system to harmonize their programmes and activities in support of the priorities for regional cooperation, economic integration and sustainable development in Central Asia, as identified by the countries of the region;</p>
        </content>
      </paragraph>
      <paragraph eId="para_57" class="MercuryDocument">
        <num>10.</num>
        <content eId="para_57__content">
          <p xml:space="preserve">	<span class="italic">Encourages</span> the efforts of the partners of the Central Asian States and the international community as a whole to strengthen and expand cooperation with the countries of the region.</p>
        </content>
      </paragraph>
    </mainBody>
