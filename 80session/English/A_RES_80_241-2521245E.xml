      <p>
        <inline name="agenda item name">Financing of the United Nations Support Office in Haiti</inline>
      </p>
      <p>
        <docTitle>Resolution adopted by the General Assembly on 30 December 2025</docTitle>
      </p>
      <p xml:space="preserve">
        <docProponent refersTo="#fifthCommittee">[on the report of the Fifth Committee (<inline name="originating document">A/80/568, para. 19</inline>)]</docProponent>
