    <preface>
      <p>
        <docNumber>80/241.</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">Financing of the United Nations Support Office in Haiti</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="italic">The General Assembly</span>,</p>
      </formula>
      <container name="Having considered" eId="container_2">
        <p xml:space="preserve">	<span class="italic">Having considered</span> the note by the Secretary-General on the financing arrangements for the United Nations Support Office in Haiti<authorialNote marker="1" placement="bottom" eId="authorialNote_1"><p xml:space="preserve">		<a href="https://docs.un.org/en/A/80/499">A/80/499</a>.</p></authorialNote> and the related report of the Advisory Committee on Administrative and Budgetary Questions,<authorialNote marker="2" placement="bottom" eId="authorialNote_2"><p xml:space="preserve">		<a href="https://docs.un.org/en/A/80/567">A/80/567</a>.</p></authorialNote></p>
      </container>
      <container name="Recalling" eId="container_3">
        <p xml:space="preserve">	<span class="italic">Recalling</span> Security Council resolution <a href="https://docs.un.org/en/S/RES/2793(2025)">2793 (2025)</a> of 30 September 2025, in which the Council requested that the Secretary-General establish the United Nations Support Office in Haiti to provide support, primarily to the Gang Suppression Force, the United Nations Integrated Office in Haiti, the Haitian National Police and the Haitian Armed Forces on any joint operations with the Gang Suppression Force, as well as technical support to the Organization of American States, in accordance with the funding modalities set out therein, with a view to assuming full logistical support responsibility for the Gang Suppression Force within six months of adoption,</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_4" class="MercuryDocument">
        <num>1.</num>
        <content eId="para_4__content">
          <p xml:space="preserve">	<span class="italic">Endorses</span> the conclusions and recommendations contained in the report of the Advisory Committee on Administrative and Budgetary Questions, and requests the Secretary-General to ensure their full implementation;</p>
        </content>
      </paragraph>
      <paragraph eId="para_5" class="MercuryDocument">
        <content eId="para_5__content">
          <p xml:space="preserve">
            <span class="bold">Estimates for the period from 1 October 2025 to 30 June 2026</span>
          </p>
        </content>
      </paragraph>
      <paragraph eId="para_6" class="MercuryDocument">
        <num>2.</num>
        <content eId="para_6__content">
          <p xml:space="preserve">	<span class="italic">Authorizes</span> the Secretary-General to establish a special account for the United Nations Support Office in Haiti for the purpose of accounting for the income received and the expenditure incurred in respect of the Office;</p>
        </content>
      </paragraph>
      <paragraph eId="para_7" class="MercuryDocument">
        <num>3.</num>
        <content eId="para_7__content">
          <p xml:space="preserve">	<span class="italic">Also authorizes </span>the Secretary-General to enter into commitments for the Office in an amount not exceeding 271,328,700 United States dollars for the period from 1 October 2025 to 30 June 2026, inclusive of the amounts of 54,163,500 dollars and of 50,000,000 dollars of the available balance of the stores available from the Organization’s strategic deployment stocks, previously authorized by the Advisory Committee for the period from 1 October to 31 December 2025 under the terms of section VI of General Assembly resolution <a href="https://docs.un.org/en/A/RES/64/269">64/269</a> of 24 June 2010;</p>
        </content>
      </paragraph>
      <paragraph eId="para_8" class="MercuryDocument">
        <content eId="para_8__content">
          <p xml:space="preserve">
            <span class="bold">Financing of the commitment authority</span>
          </p>
        </content>
      </paragraph>
      <paragraph eId="para_9" class="MercuryDocument">
        <num>4.</num>
        <content eId="para_9__content">
          <p xml:space="preserve">	<span class="italic">Decides</span> to apportion among Member States the amount of 271,328,700 dollars for the period from 1 October 2025 to 30 June 2026, in accordance with the levels updated in its resolution <a href="https://docs.un.org/en/A/RES/79/250">79/250</a> of 24 December 2024, taking into account the scale of assessments for 2025 and 2026, as set out in its resolution <a href="https://docs.un.org/en/A/RES/79/249">79/249</a> of 24 December 2024;</p>
        </content>
      </paragraph>
      <paragraph eId="para_10" class="MercuryDocument">
        <num>5.</num>
        <content eId="para_10__content">
          <p xml:space="preserve">	<span class="italic">Also decides</span> that, in accordance with the provisions of its resolution <a href="https://docs.un.org/en/A/RES/973(X)">973 (X)</a> of 15 December 1955, there shall be set off against the apportionment among Member States, as provided for in paragraph 4 above, their respective share in the Tax Equalization Fund of 1,792,900 dollars, representing the estimated staff assessment income approved for the Office for the period from 1 October 2025 to 30 June 2026;</p>
        </content>
      </paragraph>
      <paragraph eId="para_12" class="MercuryDocument">
        <num>6.</num>
        <content eId="para_12__content">
          <p xml:space="preserve">	<span class="italic">Invites</span> voluntary contributions to the United Nations trust fund established to support the Gang Suppression Force.</p>
        </content>
      </paragraph>
    </mainBody>
