        <docNumber refersTo="#symbol">A/RES/80/111</docNumber>
      </p>
      <p class="upperLeft">
        <img src="logo-un.jpg"></img>
        <docAuthority refersTo="#issuingBody" class="rightBig">Генеральная Ассамблея</docAuthority>
      </p>
      <p>
        <docStatus refersTo="#generalDistribution" class="rightSmall">Distr.: General</docStatus>
      </p>
      <p>
        <docDate date="2025-12-12" class="rightSmall" refersTo="#dateOfIssuance">12 December 2025</docDate>
      </p>
      <p>
        <session refersTo="#generalAssembly" value="80" eId="coverPage_1__session_1">Восьмидесятая сессия</session>
      </p>
      <p>
        <inline title="72 d)" name="agenda item">Пункт 72 d) повестки дня</inline>
      </p>
      <p>
        <inline name="agenda item name">Укрепление координации в области гуманитарной помощи и помощи в случае стихийных бедствий, предоставляемой Организацией Объединенных Наций, включая специальную экономическую помощь: укрепление международного сотрудничества и координация усилий в деле изучения, смягчения и минимизации последствий чернобыльской катастрофы</inline>
      </p>
      <p>
        <docTitle>Резолюция, принятая Генеральной Ассамблеей 10 декабря 2025 года</docTitle>
      </p>
      <p xml:space="preserve">
        <docProponent refersTo="#noMainCommittee">[без передачи в главные комитеты (<inline name="originating document">A/80/L.27</inline>)]</docProponent>
      </p>
    </coverPage>
    <preface>
      <p>
        <docNumber>80/111.</docNumber>
        <docTitle refersTo="#resolutionTitle">
          <span class="bold">	Укрепление международного сотрудничества и координация усилий в деле изучения, смягчения и минимизации последствий чернобыльской катастрофы</span>
        </docTitle>
      </p>
    </preface>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="italic">Генеральная Ассамблея</span>,</p>
      </formula>
      <container name="подтверждая" eId="container_2">
        <p xml:space="preserve">	<span class="italic">подтверждая</span> свою резолюцию <a href="https://docs.un.org/ru/A/RES/77/288">77/288</a> от 16 мая 2023 года,</p>
      </container>
      <container name="подтверждая также" eId="container_3">
        <p xml:space="preserve">	<span class="italic">подтверждая также</span> свою резолюцию <a href="https://docs.un.org/ru/A/RES/68/99">68/99</a> от 13 декабря 2013 года об укреплении международного сотрудничества и координации усилий в деле изучения, смягчения и минимизации последствий чернобыльской катастрофы, а также другие свои соответствующие резолюции о закрытии Чернобыльской атомной электростанции и принимая к сведению решения, принятые соответствующими органами Организации Объединенных Наций, специализированными учреждениями и другими организациями системы Организации Объединенных Наций в осуществление этих резолюций, </p>
      </container>
      <container name="учитывая" eId="container_4">
        <p xml:space="preserve">	<span class="italic">учитывая</span> ощущаемые до сих пор серьезные долговременные последствия чернобыльской катастрофы, а также сохраняющиеся в этой связи потребности пострадавших сообществ и территорий, </p>
      </container>
      <container name="подчеркивая" eId="container_5">
        <p xml:space="preserve">	<span class="italic">подчеркивая </span>необходимость дальнейшей координации Программой развития Организации Объединенных Наций деятельности системы Организации Объединенных Наций, направленной на краткосрочное и долгосрочное восстановление территорий, пострадавших от чернобыльской аварии, и необходимость укрепления учреждениями Организации Объединенных Наций стратегических партнерских связей, формирования альянсов и мобилизации ресурсов на развитие затронутых чернобыльской катастрофой территорий, </p>
      </container>
      <container name="приветствуя" eId="container_6">
        <p xml:space="preserve">	<span class="italic">приветствуя </span>мероприятия, организуемые государствами-членами, соответствующими учреждениями системы Организации Объединенных Наций и другими международными организациями, а также гражданским обществом по случаю Международного дня памяти о чернобыльской катастрофе, отмечаемого 26 апреля, и подчеркивая его значение для дальнейшего укрепления международного сотрудничества в целях изучения, смягчения и минимизации последствий чернобыльской катастрофы,</p>
      </container>
      <container name="подчеркивая" eId="container_7">
        <p xml:space="preserve">	<span class="italic">подчеркивая</span> то обстоятельство, что сороковая годовщина чернобыльской катастрофы, которая будет отмечаться в 2026 году, предоставляет всем заинтересованным сторонам критически важную возможность провести активные мероприятия в память об этом событии и подтвердить свою приверженность делу обеспечения долгосрочного восстановления, устойчивости и устойчивого развития,</p>
      </container>
      <container name="приветствуя" eId="container_8">
        <p xml:space="preserve">	<span class="italic">приветствуя</span> международные усилия по повышению осведомленности, в том числе с использованием интернет-ресурсов, о потребностях людей и территорий, пострадавших в результате чернобыльской катастрофы, </p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_9" class="MercuryDocument">
        <num>1.</num>
        <content eId="para_9__content">
          <p xml:space="preserve">	<span class="italic">приветствует </span>доклад Генерального секретаря о долгосрочных последствиях чернобыльской катастрофы<authorialNote marker="1" placement="bottom" eId="authorialNote_1"><p xml:space="preserve">		<a href="https://docs.un.org/ru/A/80/395">A/80/395</a>.</p></authorialNote>; </p>
        </content>
      </paragraph>
      <paragraph eId="para_10" class="MercuryDocument">
        <num>2.</num>
        <content eId="para_10__content">
          <p xml:space="preserve">	<span class="italic">высоко оценивает</span> координирующую роль Программы развития Организации Объединенных Наций в международном сотрудничестве по Чернобылю, включая работу, проводимую Межучрежденческой целевой группой по Чернобылю;</p>
        </content>
      </paragraph>
      <paragraph eId="para_12" class="MercuryDocument">
        <num>3.</num>
        <content eId="para_12__content">
          <p xml:space="preserve">	<span class="italic">признает</span> необходимость продолжения международного сотрудничества по Чернобылю под эгидой Организации Объединенных Наций в целях содействия осуществлению Повестки дня в области устойчивого развития на период до 2030 года<authorialNote marker="2" placement="bottom" eId="authorialNote_2"><p xml:space="preserve">		Резолюция <a href="https://docs.un.org/ru/A/RES/70/1">70/1</a>.</p></authorialNote> и Сендайской рамочной программы по снижению риска бедствий на 2015–2030 годы<authorialNote marker="3" placement="bottom" eId="authorialNote_3"><p xml:space="preserve">		Резолюция <a href="https://docs.un.org/ru/A/RES/69/283">69/283</a> Генеральной Ассамблеи, приложение II.</p></authorialNote>; </p>
        </content>
      </paragraph>
      <paragraph eId="para_15" class="MercuryDocument">
        <num>4.</num>
        <content eId="para_15__content">
          <p xml:space="preserve">	<span class="italic">подчеркивает </span>в этой связи необходимость продолжения мониторинга состояния окружающей среды и здоровья населения в регионах и сообществах, пострадавших в результате чернобыльской катастрофы, для целей оценки эффективности международной помощи;</p>
        </content>
      </paragraph>
      <paragraph eId="para_19" class="MercuryDocument">
        <num>5.</num>
        <content eId="para_19__content">
          <p xml:space="preserve">	<span class="italic">выражает серьезную тревогу</span> в связи с ущербом, который был причинен ударом БПЛА 14 февраля 2025 года по новому безопасному конфайнменту на Чернобыльской АЭС на Украине, поставившим под угрозу десятилетия международного прогресса в обеспечении надежности и безопасности этого объекта после одной из самых опасных в мире ядерных катастроф;</p>
        </content>
      </paragraph>
      <paragraph eId="para_24" class="MercuryDocument">
        <num>6.</num>
        <content eId="para_24__content">
          <p xml:space="preserve">	<span class="italic">подчеркивает</span> важность постоянной поддержки со стороны международного сообщества и соответствующих органов власти в ремонте нового безопасного конфайнмента, который имеет решающее значение для соблюдения мировых стандартов ядерной безопасности и снижения экологических рисков на Украине;</p>
        </content>
      </paragraph>
      <paragraph eId="para_30" class="MercuryDocument">
        <num>7.</num>
        <content eId="para_30__content">
          <p xml:space="preserve">	<span class="italic">рекомендует</span> государствам-членам и всем заинтересованным партнерам поддерживать международное сотрудничество по Чернобылю, направленное на достижение целей в области устойчивого развития в районах, пострадавших в результате чернобыльской катастрофы, в том числе через партнерство, инновации и инвестиции;</p>
        </content>
      </paragraph>
      <paragraph eId="para_37" class="MercuryDocument">
        <num>8.</num>
        <content eId="para_37__content">
          <p xml:space="preserve">	<span class="italic">просит</span> Программу развития Организации Объединенных Наций и Межучрежденческую целевую группу по Чернобылю продолжать координировать международное сотрудничество по Чернобылю в качестве одного из способов содействия осуществлению Повестки дня на период до 2030 года и обеспечивать постоянное уделение вопросам восстановления после чернобыльской катастрофы первоочередного внимания в межучрежденческих и международных повестках дня; </p>
        </content>
      </paragraph>
      <paragraph eId="para_45" class="MercuryDocument">
        <num>9.</num>
        <content eId="para_45__content">
          <p xml:space="preserve">	<span class="italic">признает</span> необходимость дальнейшего обеспечения устойчивого развития восстанавливающихся районов; </p>
        </content>
      </paragraph>
      <paragraph eId="para_54" class="MercuryDocument">
        <num>10.</num>
        <content eId="para_54__content">
          <p xml:space="preserve">	<span class="italic">постановляет</span> переименовать International Chernobyl Disaster Remembrance Day (Международный день памяти о чернобыльской катастрофе), провозглашенный в ее резолюции <a href="https://docs.un.org/ru/A/RES/71/125">71/125</a> от 8 декабря 2016 года и отмечаемый ежегодно с 2017 года, в International Chornobyl Disaster Remembrance Day;</p>
        </content>
      </paragraph>
      <paragraph eId="para_64" class="MercuryDocument">
        <num>11.</num>
        <content eId="para_64__content">
          <p xml:space="preserve">	<span class="italic">предлагает</span> всем государствам-членам, соответствующим учреждениям системы Организации Объединенных Наций и другим международным организациям, а также гражданскому обществу отмечать Международный день памяти о чернобыльской катастрофе, в том числе уделяя особое внимание значимости памятных мероприятий по случаю этого дня в 2026 году, и обращает внимание на то, что расходы по проведению всех соответствующих мероприятий должны покрываться за счет добровольных взносов;</p>
        </content>
      </paragraph>
      <paragraph eId="para_75" class="MercuryDocument">
        <num>12.</num>
        <content eId="para_75__content">
          <p xml:space="preserve">	<span class="italic">просит</span> Председателя Генеральной Ассамблеи провести, в рамках имеющихся ресурсов, 24 апреля 2026 года специальное памятное заседание Ассамблеи по случаю сороковой годовщины чернобыльской катастрофы;</p>
        </content>
      </paragraph>
      <paragraph eId="para_87" class="MercuryDocument">
        <num>13.</num>
        <content eId="para_87__content">
          <p xml:space="preserve">	<span class="italic">постановляет</span> включить в предварительную повестку для своей восемьдесят третьей сессии по пункту, озаглавленному «Укрепление координации в области гуманитарной помощи и помощи в случае бедствий, предоставляемой Организацией Объединенных Наций, включая специальную экономическую помощь», подпункт, озаглавленный «Укрепление международного сотрудничества и координация усилий в деле изучения, смягчения и минимизации последствий чернобыльской катастрофы»;</p>
        </content>
      </paragraph>
      <paragraph eId="para_100" class="MercuryDocument">
        <num>14.</num>
        <content eId="para_100__content">
          <p xml:space="preserve">	<span class="italic">просит</span> Генерального секретаря представить Генеральной Ассамблее на ее восемьдесят третьей сессии по подпункту под названием «Укрепление международного сотрудничества и координация усилий в деле изучения, смягчения и минимизации последствий чернобыльской катастрофы» пункта, озаглавленного «Укрепление координации в области гуманитарной помощи и помощи в случае стихийных бедствий, предоставляемой Организацией Объединенных Наций, включая специальную экономическую помощь», доклад о ходе осуществления настоящей резолюции. </p>
        </content>
      </paragraph>
    </mainBody>
