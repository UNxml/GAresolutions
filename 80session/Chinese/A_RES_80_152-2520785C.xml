      <p>
        <inline name="agenda item name">消除贫困和其他发展问题</inline>
      </p>
      <p>
        <docTitle>2025年12月15日大会决议</docTitle>
      </p>
      <p xml:space="preserve">
        <docProponent refersTo="#secondCommittee">[根据第二委员会的报告 (<inline name="originating document">A/80/555，第7段</inline>)]</docProponent>
