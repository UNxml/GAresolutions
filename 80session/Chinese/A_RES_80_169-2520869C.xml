      <p>
        <inline title="86" name="agenda item">议程项目86</inline>
      </p>
      <p>
        <inline name="agenda item name">发生灾害时的人员保护</inline>
      </p>
      <p>
        <docTitle>2025年12月15日大会决议</docTitle>
      </p>
      <p xml:space="preserve">
        <docProponent refersTo="#sixthCommittee">[根据第六委员会的报告 (<inline name="originating document">A/80/456，第10段</inline>)]</docProponent>
      </p>
