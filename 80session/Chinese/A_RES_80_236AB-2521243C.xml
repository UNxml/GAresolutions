              <location title="第69次" refersTo="#adoptionMeeting">第69次全体会议(续会)</location>
              <eol />
              <docDate date="2025-12-30" refersTo="#adoptionDate">2025年12月30日</docDate>
            </event>
          </p>
        </conclusions>
      </statement>
